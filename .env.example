# Copiad este fichero a .env y ajustad si hace falta.
# El default es Ollama LOCAL (lo que exige el enunciado para banda 5).

# --- LLM y embeddings ---
OLLAMA_URL=http://localhost:11434/api
LLM_MODEL=gemma2:27b
EMBED_MODEL=nomic-embed-text

# Si en desarrollo queréis tirar contra el endpoint UPV (requiere VPN o estar en red UPV):
# OLLAMA_URL=https://ollama.gti-ia.upv.es/api
# VERIFY_SSL=false   # cert autofirmado en el endpoint UPV

VERIFY_SSL=true

# --- Vector store ---
CHROMA_PATH=./data/chroma
COLLECTION_NAME=gti_orienta

# --- API ---
API_HOST=127.0.0.1
API_PORT=8000
